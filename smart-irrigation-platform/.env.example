# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/smart_irrigation
MONGODB_URI_TEST=mongodb://localhost:27017/smart_irrigation_test

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Cache TTLs (seconds) ─────────────────────────────────────────────────────
CACHE_TTL_SUMMARY=60
CACHE_TTL_LATEST_READING=180
CACHE_TTL_ROLLING_AVG=300

# ─── Sensor thresholds ────────────────────────────────────────────────────────
MOISTURE_MIN=5
MOISTURE_MAX=95
TEMPERATURE_MIN=-10
TEMPERATURE_MAX=60
WATER_FLOW_MIN=0

# ─── Alert rules ──────────────────────────────────────────────────────────────
# How many minutes before a sensor is considered missing
MISSING_READING_THRESHOLD_MINUTES=2

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
